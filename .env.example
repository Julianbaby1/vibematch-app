# ─────────────────────────────────────────
# Second Wind — Environment Variables
# Copy this file to .env.local (frontend)
# and server/.env (backend)
# ─────────────────────────────────────────

# ── Supabase (both frontend and backend need these) ──────────────
# Get these from: https://app.supabase.com → Project Settings → API

# Your project URL (safe to expose publicly)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Anonymous/public key (safe to expose publicly — RLS enforces access)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...your-anon-key

# Service Role key (KEEP SECRET — bypasses RLS — backend only)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...your-service-role-key

# ── Express API (backend) ─────────────────────────────────────────
PORT=3001
NODE_ENV=development

# CORS — set to your frontend URL in production
FRONTEND_URL=http://localhost:3000

# ── Frontend (Next.js) ────────────────────────────────────────────
# Where the Express API is hosted
# Development: http://localhost:3001
# Production:  https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Cron job security ─────────────────────────────────────────────
# Used by the ghosting-check job endpoint
JOB_SECRET=your-random-job-secret-here
